{
  "commands": [
    { "command": "dt init",               "module": "dt/init.py",         "functions": ["init_project"] },
    { "command": "dt clone",              "module": "dt/clone.py",        "functions": ["clone_project"] },
    { "command": "dt config",             "module": "dt/config.py",       "functions": ["get_value", "set_value"] },
    { "command": "dt cache",              "module": "dt/cache.py",        "functions": ["cache_init", "cache_rm", "cache_validate"] },
    { "command": "dt remote",             "module": "dt/remote.py",       "functions": ["remote_init", "remote_list"] },
    { "command": "dt diff",               "module": "dt/diff.py",         "functions": ["tree_diff", "content_diff"] },
    { "command": "dt doctor",             "module": "dt/doctor.py",       "functions": ["run_checks"] },
    { "command": "dt push",               "module": "dt/push.py",         "functions": ["push_files"] },
    { "command": "dt add",                "module": "dt/add.py",          "functions": ["add_files"] },
    { "command": "dt fetch",              "module": "dt/fetch.py",        "functions": ["fetch_files"] },
    { "command": "dt pull",               "module": "dt/pull.py",         "functions": ["pull_files"] },
    { "command": "dt data status",        "module": "dt/data_status.py",  "functions": ["data_status"] },
    { "command": "dt status",             "module": "dt/status.py",       "functions": ["show_status"] },
    { "command": "dt du",                 "module": "dt/du.py",           "functions": ["disk_usage"] },
    { "command": "dt ls",                 "module": "dt/ls.py",           "functions": ["list_files"] },
    { "command": "dt find",               "module": "dt/find.py",         "functions": ["find_by_hash"] },
    { "command": "dt history",            "module": "dt/history.py",      "functions": ["file_history"] },
    { "command": "dt mv",                 "module": "dt/mv.py",           "functions": ["move_file"] },
    { "command": "dt import",             "module": "dt/import_data.py",  "functions": ["import_data"] },
    { "command": "dt update",             "module": "dt/update.py",       "functions": ["update_imports"] },
    { "command": "dt migrate",            "module": "dt/migrate.py",      "functions": ["migrate_files"] },
    { "command": "dt tmp",                "module": "dt/tmp.py",          "functions": ["clone_tmp", "list_tmp", "clean_tmp"] },
    { "command": "dt offline",            "module": "dt/offline.py",      "functions": ["enable_offline", "disable_offline"] },
    { "command": "dt worktree",           "module": "dt/worktree.py",     "functions": ["add_worktree", "list_worktrees", "remove_worktree"] },
    { "command": "dt index",              "module": "dt/index.py",        "functions": [] },
    { "command": "dt summary",            "module": "dt/summary.py",      "functions": ["generate_tree", "generate_dag", "generate_all"] },
    { "command": "dt install",            "module": "dt/install.py",      "functions": [] },
    { "command": "dt hook",               "module": "dt/hpc.py",          "functions": ["submit_job"] },
    { "command": "dt auth setup",         "module": "dt/auth/setup.py",   "functions": ["auth_setup"] },
    { "command": "dt auth list",          "module": "dt/auth/endpoints.py", "functions": ["discover_endpoints", "classify_url"] },
    { "command": "dt auth check",         "module": "dt/auth/checks.py",  "functions": ["check_endpoints"] },
    { "command": "dt auth whoami",        "module": "dt/auth/identity.py","functions": ["detect_identities", "get_identities"] },
    { "command": "dt auth request",       "module": "dt/auth/request.py", "functions": ["generate_request", "send_request"] },
    { "command": "dt auth teams",         "module": "dt/auth/teams.py",   "functions": ["list_repo_teams", "list_user_teams"] },
    { "command": "dt auth credentials",   "module": "dt/auth/credentials.py", "functions": ["install_credentials", "uninstall_credentials", "get_credentials_status", "check_secret", "list_repo_secrets", "set_secret"] }
  ],
  "modules": [
    { "file": "dt/cli.py",                "description": "All Click CLI commands (~3600 lines). Each command delegates immediately to its module." },
    { "file": "dt/errors.py",             "description": "Exception hierarchy: DiffError, AuthError, SummaryError, etc." },
    { "file": "dt/utils.py",              "description": "Shared helpers: get_project_name(), check_dvc(), DependencyError." },
    { "file": "dt/dvc_utils.py",          "description": "Thin wrappers around raw dvc subprocess calls." },
    { "file": "dt/config.py",             "description": ".dt/config.yaml read/write. Keys: secrets.backend, secrets.gcp.project, secrets.prefix, summary.output_dir, auth.owner.", "exports": ["get_value", "set_value"] },
    { "file": "dt/cache_ops.py",          "description": "Cache population helpers (internal)." },
    { "file": "dt/cache_index.py",        "description": "Fast existence cache / cache index." },
    { "file": "dt/hpc.py",                "description": "HPC parallel job submission via qxub. Used by push, fetch, add, data-status." },
    { "file": "dt/diff.py",               "description": "Diff system. DiffHandler ABC, plugin registry (dvc_tools.diff_handlers entry-point group), content_diff(), tree_diff(). File fetching via 'dvc get --rev' subprocess (not dvc.api).", "exports": ["DiffHandler", "register_handler", "get_handler", "list_handlers", "content_diff", "tree_diff"] },
    { "file": "dt/summary.py",            "description": "Project summary generation. generate_dag() runs 'dvc dag --md' → docs/dag.md. generate_tree() runs 'dvc list --tree' → docs/tree.txt.", "exports": ["generate_dag", "generate_tree", "generate_all"] },
    { "file": "dt/auth/__init__.py",      "description": "Re-exports all public auth names. Backward-compat patch target." },
    { "file": "dt/auth/credentials.py",   "description": "S3 credential install/uninstall/status for DVC remotes. SecretInfo dataclass, check/list/set secret helpers.", "exports": ["install_credentials", "uninstall_credentials", "get_credentials_status", "SecretInfo", "check_secret", "list_repo_secrets", "set_secret"] },
    { "file": "dt/auth/endpoints.py",     "description": "Discover DVC remotes and import sources. Classify URLs by protocol (s3/gs/ssh/https).", "exports": ["Endpoint", "classify_url", "discover_endpoints", "discover_endpoints_from_repo"] },
    { "file": "dt/auth/checks.py",        "description": "Per-protocol connectivity checks (S3, GS, SSH, HTTP, GDrive). Used by dt auth check.", "exports": ["check_endpoints", "CheckResult"] },
    { "file": "dt/auth/identity.py",      "description": "Identity detection (dt auth whoami): git, gh CLI, gcloud.", "exports": ["detect_identities", "get_identities", "Identity"] },
    { "file": "dt/auth/teams.py",         "description": "GitHub team membership queries and management.", "exports": ["list_repo_teams", "list_user_teams", "add_team_to_repo"] },
    { "file": "dt/auth/request.py",       "description": "Access request generation and delivery (email/Slack).", "exports": ["generate_request", "send_request", "AccessRequest"] },
    { "file": "dt/auth/ssh.py",           "description": "SSH key setup and deployment (dt auth setup SSH step).", "exports": ["ssh_setup"] },
    { "file": "dt/auth/setup.py",         "description": "Orchestrates full dt auth setup workflow.", "exports": ["auth_setup", "SetupReport"] },
    { "file": "dt/auth/_helpers.py",      "description": "Shared low-level helpers used across auth submodules." },
    { "file": "dt/secrets/base.py",       "description": "SecretBackend ABC, SecretError, S3Credentials dataclass. Abstract methods: get_raw_config, secret_exists, list_secrets, set_secret.", "exports": ["SecretBackend", "SecretError", "S3Credentials"] },
    { "file": "dt/secrets/gcp.py",        "description": "GCP Secret Manager backend. Python client with automatic gcloud CLI fallback (used when ADC unavailable). list_secrets/set_secret always use gcloud CLI.", "exports": ["GCPSecretBackend"] },
    { "file": "dt/secrets/__init__.py",   "description": "Re-exports GCPSecretBackend, SecretBackend, SecretError." }
  ]
}
