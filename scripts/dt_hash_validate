#!/bin/bash
set -e

file_hash="$1"
if [ -z "$file_hash" ]; then
    echo "Usage: $0 <file_hash>"
    exit 1
fi

# Get the DVC cache directory
dvc_cache_dir=$(dvc cache dir)
echo "Using DVC cache directory: $dvc_cache_dir"

    file_path="$dvc_cache_dir/files/md5/${file_hash:0:2}/${file_hash:2}"
    
    # Check if the file exists
    if [ ! -f "$file_path" ]; then
        echo "Error: File with hash '$file_hash' does not exist in DVC cache."
        exit 1
    fi


# Check if it's a directory hash
if [[ "$file_hash" == *".dir" ]]; then
    # This is a directory hash
    nodir_hash="${file_hash%.dir}"  # Remove the .dir suffix
    echo "Processing directory hash: $file_hash (base hash: $nodir_hash)"
    
    # Validate the directory metadata file's checksum
    observed_hash=$(md5sum "$file_path" | awk '{ print $1 }')
    if [ "$observed_hash" != "$nodir_hash" ]; then
        echo "Error: Expected '$file_hash'. Found $observed_hash for $file_path"
        exit 1
    fi
    
    echo "Directory with hash '$file_hash' has valid metadata."
fi