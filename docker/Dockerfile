# Generated by Absconda

FROM mambaorg/micromamba:1.5.5 AS builder

USER root
RUN apt-get update && apt-get install -y --no-install-recommends git && rm -rf /var/lib/apt/lists/*
USER $MAMBA_USER

COPY <<'ABSCONDA_ENV' /tmp/env.yaml
name: dt
channels:
- conda-forge
- default
dependencies:
- dvc
- dvc-ssh
- dvc-gs
- dvc-s3
- dvc-gdrive
- pandas
- yq
- parallel
- gh
- google-cloud-secret-manager
- awscli
- pip
- pip:
  - daff
  - git+https://github.com/swarbricklab/dvc_tools.git
  - git+https://github.com/swarbricklab/qxub.git
ABSCONDA_ENV


RUN micromamba install -y -n base --channel conda-forge --channel default conda-pack && \
    micromamba create -y -n dt -f /tmp/env.yaml && \
    micromamba run -n base conda-pack -p /opt/conda/envs/dt -o /tmp/absconda-env.tar.gz && \
    rm -rf /opt/conda/envs/dt && \
    mkdir -p /opt/conda/envs/dt && \
    tar -xzf /tmp/absconda-env.tar.gz -C /opt/conda/envs/dt && \
    rm /tmp/absconda-env.tar.gz && \
    if [ -x "/opt/conda/envs/dt/bin/conda-unpack" ]; then micromamba run -n base python /opt/conda/envs/dt/bin/conda-unpack && rm -rf
/opt/conda/envs/dt/conda-meta/history; fi


FROM debian:bookworm-slim AS runtime
# Generate common locales to avoid setlocale warnings when host locale leaks in
RUN apt-get update -qq && apt-get install -y -qq --no-install-recommends locales > /dev/null 2>&1 \
    && sed -i 's/^# *\(en_US.UTF-8\)/\1/' /etc/locale.gen \
    && sed -i 's/^# *\(en_AU.UTF-8\)/\1/' /etc/locale.gen \
    && locale-gen \
    && apt-get clean && rm -rf /var/lib/apt/lists/*
ENV LANG=en_US.UTF-8 LC_ALL=en_US.UTF-8
COPY --from=builder /opt/conda/envs/dt/ /opt/conda/envs/dt/

ENV CONDA_DEFAULT_ENV=dt
ENV CONDA_PREFIX=/opt/conda/envs/dt
ENV PATH=/opt/conda/envs/dt/bin:/opt/conda/bin:${PATH}

CMD ["python"]

